<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".GroceriesList.GroceriesListActivity">

    <fragment
        android:id="@+id/listView"
        android:name="com.example.littleshelf.GroceriesList.GroceriesListFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp" />

    <fragment
        android:id="@+id/bottomNavigationMenu"
        android:name="com.example.littleshelf.BottomNavigationMenuFragment"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="0dp" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/addItem"
        android:name="com.example.littleshelf.GroceriesList.AddGroceryItemFragment"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/buttonCheese"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginBottom="-600dp"
        android:background="#FFFFFF"
        android:gravity="center"
        app:backgroundTint="#fc0"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigationMenu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.95"
        app:layout_constraintStart_toStartOf="@+id/listView"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>